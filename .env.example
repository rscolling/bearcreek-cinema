# Bear Creek Cinema — environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# === Jellyfin (required) ===
JELLYFIN_API_KEY=
JELLYFIN_USER_ID=

# === TMDb (required for metadata enrichment) ===
# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# === Anthropic Claude (optional — only if you enable ClaudeProvider) ===
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# === Dev-only overrides ===
# Use a non-standard config file location
# ARCHIVE_AGENT_CONFIG=./config.toml

# Override log level
# ARCHIVE_AGENT_LOG_LEVEL=DEBUG

# Point at a remote Ollama (e.g., over Tailscale when developing on a
# different machine than don-quixote)
# OLLAMA_HOST=http://don-quixote.tailnet.ts.net:11434
